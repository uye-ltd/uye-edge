# Development environment — self-signed certs, local upstream stub
NGINX_DOMAIN=localhost

NGINX_SSL_CERT_PATH=/etc/nginx/ssl/selfsigned.crt
NGINX_SSL_KEY_PATH=/etc/nginx/ssl/selfsigned.key
NGINX_SSL_CHAIN_PATH=/etc/nginx/ssl/selfsigned.crt

NGINX_UPSTREAM_HOST=go-gateway
NGINX_UPSTREAM_PORT=80

NGINX_LB_ALGORITHM=

NGINX_RATE_LIMIT_RATE=1000r/m
NGINX_RATE_LIMIT_BURST=200

NGINX_RATE_LIMIT_AUTH_RATE=100r/m
NGINX_RATE_LIMIT_AUTH_BURST=50

NGINX_RATE_LIMIT_GENERAL_RATE=2000r/m
NGINX_RATE_LIMIT_GENERAL_BURST=500

NGINX_CONN_LIMIT_PER_IP=100
