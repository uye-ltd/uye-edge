# ============================================================================
# uye-edge — NGINX Edge Gateway environment variables
# Copy to .env (production) or .env.dev (development) and fill in the values.
# ============================================================================

# ----------------------------------------------------------------------------
# Domain & TLS
# ----------------------------------------------------------------------------
NGINX_DOMAIN=example.com
CERTBOT_EMAIL=admin@example.com

# Paths to TLS certificate files inside the container.
# With Certbot / Let's Encrypt these are typically under /etc/letsencrypt/live/.
# With cert-manager (Kubernetes) or self-signed certs, adjust accordingly.
NGINX_SSL_CERT_PATH=/etc/nginx/ssl/live/example.com/fullchain.pem
NGINX_SSL_KEY_PATH=/etc/nginx/ssl/live/example.com/privkey.pem
NGINX_SSL_CHAIN_PATH=/etc/nginx/ssl/live/example.com/chain.pem

# ----------------------------------------------------------------------------
# Upstream — Go Gateway
# ----------------------------------------------------------------------------
NGINX_UPSTREAM_HOST=go-gateway
NGINX_UPSTREAM_PORT=8080

# Load balancing algorithm directive (value must include the trailing semicolon).
# Options:
#   Round-robin (default) — leave empty
#   Least connections     — least_conn;
#   IP hash               — ip_hash;
NGINX_LB_ALGORITHM=least_conn;

# Docker image for the go-gateway service stub (used only with the 'stub' profile)
GO_GATEWAY_IMAGE=nginx:alpine

# ----------------------------------------------------------------------------
# Rate limiting
# ----------------------------------------------------------------------------
# /api/* routes
NGINX_RATE_LIMIT_RATE=100r/m
NGINX_RATE_LIMIT_BURST=20

# /api/auth/* routes (stricter)
NGINX_RATE_LIMIT_AUTH_RATE=10r/m
NGINX_RATE_LIMIT_AUTH_BURST=5

# All other routes
NGINX_RATE_LIMIT_GENERAL_RATE=200r/m
NGINX_RATE_LIMIT_GENERAL_BURST=50

# Maximum concurrent connections per IP across all location blocks
NGINX_CONN_LIMIT_PER_IP=20
